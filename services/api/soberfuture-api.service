[Unit]
Description=SoberFuture Core API
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/soberfuture/services/api
ExecStart=/opt/soberfuture/services/api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
EnvironmentFile=/opt/soberfuture/.env.production
StandardOutput=journal
StandardError=journal
SyslogIdentifier=soberfuture-api

[Install]
WantedBy=multi-user.target
