[Unit]
Description=SoberFuture MCP Gateway
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/soberfuture/services/mcp-gateway
ExecStart=/opt/soberfuture/services/mcp-gateway/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8100 --workers 2
Restart=always
RestartSec=5
EnvironmentFile=/opt/soberfuture/.env.production
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mcp-gateway

[Install]
WantedBy=multi-user.target
